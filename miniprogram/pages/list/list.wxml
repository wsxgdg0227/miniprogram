<view class="container">
  <view class="header">CppTemplate Cloud</view>
  <view class="sub-header">随时查看你的代码仓库</view>

  <scroll-view scroll-x="true" class="category-scroll">
    <view class="category-row">
      <view
        class="category-chip {{selectedCategory === item ? 'chip-active' : ''}}"
        wx:for="{{categories}}"
        wx:key="*this"
        data-category="{{item}}"
        bindtap="onCategoryTap"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <block wx:if="{{loading}}">
    <view class="state">加载中...</view>
  </block>

  <block wx:elif="{{errorMsg}}">
    <view class="state error">{{errorMsg}}</view>
  </block>

  <block wx:elif="{{snippets.length === 0}}">
    <view class="state">暂无数据，请先上传 .cpp 文件</view>
  </block>

  <block wx:else>
    <view
      class="card"
      wx:for="{{snippets}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view class="card-top">
        <view class="title">{{item.title}}</view>
        <view class="tag">{{item.category}}</view>
      </view>
      <view class="meta">{{item.created_at}}</view>
    </view>
  </block>
</view>
